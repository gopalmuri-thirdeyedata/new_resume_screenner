VAPI_PRIVATE_KEY=your_vapi_private_key_here
VAPI_PUBLIC_KEY=your_vapi_public_key_here


PISTON_API_URL=https://emkc.org/api/v2/piston/execute
PISTON_API_KEY=
PISTON_API_HOST=
PISTON_BEARER_TOKEN=

FRONTEND_URL=http://localhost:5173

# Admin Access Control (RBAC)
# Comma-separated list of email addresses that receive the "admin" role on first login.
# Add any HR admin or super-admin email here. Do NOT hardcode emails in source code.
ADMIN_EMAILS=admin@yourcompany.com,hr@yourcompany.com

# OneDrive / Microsoft Azure App Registration
# Register an app at https://portal.azure.com → App registrations
# Add redirect URI: http://localhost:8000/onedrive/callback/
# Grant API permissions: Files.ReadWrite.All, User.Read (delegated)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common
ONEDRIVE_AUTHORITY_URL=https://login.microsoftonline.com
ONEDRIVE_REDIRECT_URI=http://localhost:8000/onedrive/callback/
